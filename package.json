{
  "name": "daily-qa",
  "version": "1.0.0",
  "private": true,
  "description": "每日问答工具 - 前后端统一管理",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently -n client,server -c green,blue \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build:client",
    "build:client": "npm run build --workspace=client",
    "check": "npm run lint",
    "lint": "npm run lint:client && npm run lint:server",
    "lint:client": "npm run lint --workspace=client",
    "lint:server": "npm run lint --workspace=server",
    "lint:fix": "npm run lint:fix:client && npm run lint:fix:server",
    "lint:fix:client": "npm run lint:fix --workspace=client",
    "lint:fix:server": "npm run lint:fix --workspace=server",
    "start": "npm run start:server",
    "start:server": "npm run start --workspace=server",
    "preview": "npm run preview --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
